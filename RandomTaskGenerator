# Работа с файлами
def load_tasks():
    """Загружает задачи из JSON файла"""
    if os.path.exists(TASKS_FILE):
        try:
            with open(TASKS_FILE, "r", encoding="utf-8") as file:
                return json.load(file)
        except (json.JSONDecodeError, IOError):
            return DEFAULT_TASKS.copy()
    else:
        save_tasks(DEFAULT_TASKS)
        return DEFAULT_TASKS.copy()

def save_tasks(tasks):
    """Сохраняет задачи в JSON файл"""
    try:
        with open(TASKS_FILE, "w", encoding="utf-8") as file:
            json.dump(tasks, file, ensure_ascii=False, indent=4)
    except IOError:
        messagebox.showerror("Ошибка", "Не удалось сохранить задачи!")

def load_history():
    """Загружает историю из JSON файла"""
    if os.path.exists(HISTORY_FILE):
        try:
            with open(HISTORY_FILE, "r", encoding="utf-8") as file:
                return json.load(file)
        except (json.JSONDecodeError, IOError):
            return []
    return []

def save_history(history):
    """Сохраняет историю в JSON файл"""
    try:
        with open(HISTORY_FILE, "w", encoding="utf-8") as file:
            json.dump(history, file, ensure_ascii=False, indent=4)
    except IOError:
        messagebox.showerror("Ошибка", "Не удалось сохранить историю!")

def add_to_history(task):
    """Добавляет задачу в историю"""
    history = load_history()
    entry = {
        "date": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        "text": task["text"],
        "type": task["type"]
    }
    history.append(entry)
    save_history(history)
    update_history_display(history)

#Функции управления задачами
def add_new_task():
    """Добавляет новую задачу"""
    text = new_task_text.get().strip()
    task_type = new_task_type_var.get()
    
    if not text:
        messagebox.showwarning("Предупреждение", "Введите текст задачи!")
        return
    
    if not task_type:
        messagebox.showwarning("Предупреждение", "Выберите тип задачи!")
        return
    
    new_task = {"text": text, "type": task_type}
    tasks.append(new_task)
    save_tasks(tasks)
    
    # Обновляем выпадающий список типов
    update_type_list()
    
    # Очищаем поля
    new_task_text.delete(0, tk.END)
    new_task_type_var.set("")
    
    messagebox.showinfo("Успех", "Задача добавлена!")

def delete_task():
    """Удаляет выбранную задачу из списка"""
    selected = tasks_listbox.curselection()
    if not selected:
        messagebox.showwarning("Предупреждение", "Выберите задачу для удаления!")
        return
    
    if messagebox.askyesno("Подтверждение", "Удалить эту задачу из списка?"):
        index = selected[0]
        tasks.pop(index)
        save_tasks(tasks)
        update_tasks_display()
        update_type_list()
        messagebox.showinfo("Успех", "Задача удалена!")

def generate_task():
    """Генерирует случайную задачу с учётом фильтрации"""
    if not tasks:
        messagebox.showwarning("Предупреждение", "Нет доступных задач!")
        return
    
    # Получаем выбранный фильтр
    type_filter = filter_type_var.get()
    
    # Фильтруем задачи
    filtered_tasks = tasks.copy()
    if type_filter != "Все типы":
        filtered_tasks = [t for t in filtered_tasks if t["type"] == type_filter]
    
    if not filtered_tasks:
        messagebox.showinfo("Информация", f"Нет задач типа '{type_filter}'!")
        return
    
    # Выбираем случайную задачу
    random_task = random.choice(filtered_tasks)
    
    # Отображаем задачу
    current_task_text.config(state="normal")
    current_task_text.delete("1.0", tk.END)
    current_task_text.insert("1.0", random_task["text"])
    current_task_text.config(state="disabled")
    
    current_task_type.config(text=f"Тип: {random_task['type']}", fg="#2196F3")
    
    # Сохраняем в историю
    add_to_history(random_task)

def mark_as_done():
    """Отмечает текущую задачу как выполненную и генерирует новую"""
    if current_task_text.get("1.0", tk.END).strip():
        messagebox.showinfo("Отлично!", "Задача выполнена! Генерируем новую...")
        generate_task()
    else:
        messagebox.showwarning("Предупреждение", "Сначала сгенерируйте задачу!")

def update_tasks_display():
    """Обновляет отображение списка задач"""
    tasks_listbox.delete(0, tk.END)
    for task in tasks:
        tasks_listbox.insert(tk.END, f"[{task['type']}] {task['text']}")

def update_type_list():
    """Обновляет список типов в выпадающих списках"""
    types = sorted(set(t["type"] for t in tasks))
    filter_type_combo["values"] = ["Все типы"] + types
    new_task_type_combo["values"] = types

def update_history_display(history):
    """Обновляет отображение истории"""
    history_listbox.delete(0, tk.END)
    
    for entry in reversed(history[-15:]):  # Показываем последние 15
        display_text = f"{entry['date'][:10]} | [{entry['type']}] {entry['text'][:40]}..."
        history_listbox.insert(tk.END, display_text)
    
    history_count_label.config(text=f"Всего записей в истории: {len(history)}")

def clear_history():
    """Очищает историю"""
    if messagebox.askyesno("Подтверждение", "Вы уверены, что хотите очистить всю историю?"):
        save_history([])
        update_history_display([])
        messagebox.showinfo("Успех", "История очищена!")

def reset_filters():
    """Сбрасывает фильтры"""
    filter_type_var.set("Все типы")

def show_task_details(event):
    """Показывает детали выбранной задачи из истории"""
    selected = history_listbox.curselection()
    if selected:
        history = load_history()
        index = len(history) - 1 - selected[0]
        if 0 <= index < len(history):
            task = history[index]
            details_text = f"Дата: {task['date']}\n\n"
            details_text += f"Задача:\n{task['text']}\n\n"
            details_text += f"Тип: {task['type']}"
            
            messagebox.showinfo("Детали задачи", details_text)

